import os, json, requests
from datetime import datetime

CLAUDE_KEY = os.environ["ANTHROPIC_API_KEY"]
TG_TOKEN   = os.environ["TELEGRAM_TOKEN"]
TG_CHAT    = os.environ["TELEGRAM_CHAT_ID"]

today = datetime.now().strftime("%Y년 %m월 %d일")

# Claude API 호출 (웹서치 포함)
res = requests.post(
    "https://api.anthropic.com/v1/messages",
    headers={
        "x-api-key": CLAUDE_KEY,
        "anthropic-version": "2023-06-01",
        "content-type": "application/json"
    },
    json={
        "model": "claude-sonnet-4-20250514",
        "max_tokens": 1000,
        "tools": [{"type": "web_search_20250305", "name": "web_search"}],
        "system": "당신은 망원동 로컬 큐레이터입니다. 웹서치로 최신 정보를 찾아 텔레그램 메시지 형식으로 작성하세요. 이모지 풍부하게 사용.",
        "messages": [{
            "role": "user",
            "content": f"""오늘은 {today}입니다.
이번 주말 망원동 가족 나들이 추천을 위해 아래를 검색해서 정리해주세요:
1. 최근 유튜버가 다녀간 망원동 맛집/카페/빵집
2. 구글 리뷰 최근 급증한 핫플
3. 망원 한강공원 주변 즐길거리

형식:
🗺 이번 주말 망원동 추천

📌 [장소명]
카테고리 | 한 줄 소개
💡 팁: 방문 팁
📎 출처: 정보 출처

(5-6곳 추천 후)

👨‍👩‍👧 추천 코스: 오전→점심→오후 한 줄 요약"""
        }]
    }
)

text = "\n".join(
    b["text"] for b in res.json()["content"] if b["type"] == "text"
)

# 텔레그램 전송
requests.post(
    f"https://api.telegram.org/bot{TG_TOKEN}/sendMessage",
    json={"chat_id": TG_CHAT, "text": text, "parse_mode": "Markdown"}
)

print("전송 완료")
